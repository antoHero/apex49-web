{
  "name": "apex49-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "workers/*"
  ],
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run lint:env",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:env": "tsx scripts/check-env-safety.ts",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "dev:full": "opennextjs-cloudflare build && wrangler dev -c wrangler.toml -c workers/email-consumer/wrangler.toml --persist-to .wrangler/state",
    "cache:purge": "curl -X POST \"https://api.cloudflare.com/client/v4/zones/$CF_PURGE_ZONE_ID/purge_cache\" -H \"Authorization: Bearer $CF_PURGE_TOKEN\" -H \"Content-Type: application/json\" --data '{\"purge_everything\":true}'",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy && npm run cache:purge",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "deploy:consumer": "npm run deploy --workspace=email-consumer",
    "deploy:all": "npm run deploy:consumer && npm run deploy",
    "consumer:dev": "npm run dev --workspace=email-consumer",
    "consumer:tail": "wrangler tail --config workers/email-consumer/wrangler.toml",
    "db:push": "supabase db push"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "@types/nodemailer": "^8.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto": "^1.0.1",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nextjs-turnstile": "^1.0.5",
    "nodemailer": "^9.0.1",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "resend": "^6.16.0",
    "shadcn": "^4.11.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.106.0"
  }
}
